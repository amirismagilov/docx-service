{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "v1 HTTP Requests (rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(docx_v1_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "v1 HTTP p95 duration (s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(docx_v1_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Generation outcomes (rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(docx_generation_total[5m])) by (mode, status)",
          "legendFormat": "{{mode}}/{{status}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Generation p95 duration (s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(docx_generation_duration_seconds_bucket[5m])) by (le, mode))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "title": "Async queue depth",
      "type": "timeseries",
      "targets": [
        {
          "expr": "docx_async_queue_depth",
          "legendFormat": "queue",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["docx", "v1", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "DOCX v1 Overview",
  "version": 1
}
